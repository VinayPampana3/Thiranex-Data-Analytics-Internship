{
  "name": "Amazon Netflix Modern Dark",
  "dataColors": [
    "#A855F7",
    "#14B8A6",
    "#3B82F6",
    "#F97316",
    "#94A3B8",
    "#EC4899",
    "#F59E0B",
    "#1E293B"
  ],
  "background": "#0F172A",
  "foreground": "#F1F5F9",
  "tableAccent": "#A855F7",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#1E293B" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": true
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#FFFFFF" } }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "transparency": 0
          }
        ]
      }
    }
  }
}
