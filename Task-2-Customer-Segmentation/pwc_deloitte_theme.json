{
  "name": "Deloitte PwC Corporate Slate",
  "dataColors": [
    "#1E293B",
    "#14B8A6",
    "#3B82F6",
    "#F97316",
    "#94A3B8",
    "#A855F7",
    "#EC4899",
    "#E2E8F0"
  ],
  "background": "#F8FAFC",
